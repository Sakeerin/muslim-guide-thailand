{
  "expo": {
    "name": "Muslim Guide Thailand",
    "slug": "muslim-guide-thai",
    "scheme": "muslimguide",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.vbeyond.muslimguide"
    },
    "android": {
      "package": "co.vbeyond.muslimguide"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Muslim Guide uses your location to point you toward the Qibla and to find halal places near you. Your location stays on your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportsRTL": true
    }
  }
}
