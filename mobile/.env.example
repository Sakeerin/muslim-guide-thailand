# Base URL of the deployed web app that serves /api/v1 and /api/auth.
# On a physical device during dev this MUST be a LAN IP or a tunnelled HTTPS
# URL — "localhost" resolves to the phone itself, not your dev machine.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Community UGC (reviews + Q&A). Set to "on" only after the server flag
# (COMMUNITY_UGC_ENABLED) is on and counsel has signed off the risk-keyword
# list. Anything other than "on" hides the reviews + Q&A UI. Inlined at build
# time — changing it requires a rebuild.
EXPO_PUBLIC_COMMUNITY_UGC=
