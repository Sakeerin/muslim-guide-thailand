# Copy to .env and adjust. Never commit .env.
DATABASE_URL=postgres://mgt:mgt_dev_password@localhost:5432/muslim_guide_thai

# Better Auth (staff accounts only in MVP)
BETTER_AUTH_SECRET=change-me-generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# SMTP (dev: mailpit — pnpm dev:services)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@localhost

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Community UGC (reviews + Q&A). OFF unless "on" — keep it off in production
# until the risk-keyword list (src/lib/review-moderation.ts) is signed off by
# counsel. Gates both the write APIs and the UI that renders them.
COMMUNITY_UGC_ENABLED=

# Analytics (optional — cookieless Umami). Leave unset to disable.
# NEXT_PUBLIC_UMAMI_SRC=https://analytics.example.com/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000

# Web Push (VAPID) — generate once: npx web-push generate-vapid-keys --json
# Regenerating INVALIDATES every existing subscription, so generate only once.
# The private key is server-only — never expose it with a NEXT_PUBLIC_ prefix.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@localhost
# Same value as VAPID_PUBLIC_KEY — the browser needs it at subscribe time.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Native (Expo) push — OPTIONAL. Only needed if you enable "Enhanced Security
# for Push Notifications" on your Expo account. Leave unset otherwise.
# EXPO_ACCESS_TOKEN=
